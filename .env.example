# ────────────────────────────────────────────────────────────────────────────
# Invendis — Environment Variables Reference
# Copy this file to .env (never commit .env to git)
# ────────────────────────────────────────────────────────────────────────────

# ── Supabase (required by both services) ─────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ── AWS S3 + Rekognition (required by API server) ────────────────────────────
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION=eu-west-2
AWS_S3_BUCKET=<your-s3-bucket-name>

# ── Twilio SMS (required by API server) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
TWILIO_PHONE_NUMBER=+1234567890

# ── Auth (required by API server) ────────────────────────────────────────────
SESSION_SECRET=<long-random-string-min-32-chars>
JWT_SECRET=<long-random-string-min-32-chars>

# ── Server runtime (required by both services) ───────────────────────────────
# Railway injects PORT automatically — do not set it manually on Railway.
PORT=8080

# ── GPS-Trace hardware tracker integration ───────────────────────────────────
# Obtain an API token from GPS-Trace → My Account → API Access → Generate Token
GPSTRACE_TOKEN=<your-gpstrace-api-token>
# Optional: custom Wialon host if not using the default hst-api.wialon.com
# GPSTRACE_HOST=hst-api.wialon.com

# ── CORS (API server) ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API server.
# Set to the Railway URL of the web portal service.
# Leave unset to allow all origins (open — only acceptable in dev).
CORS_ORIGIN=https://invendis-portal.up.railway.app

# ── Web portal build-time variables ──────────────────────────────────────────
# These are baked into the JS bundle by Vite at build time.
# Set them as Railway build variables (not runtime env vars) on the portal service.
VITE_API_URL=https://invendis-api.up.railway.app
# SUPABASE_URL and SUPABASE_ANON_KEY are also read at build time by vite.config.ts

# ── Replit-specific (not used on Railway) ────────────────────────────────────
# BASE_PATH=/          # Replit proxy path prefix — defaults to "/" on Railway
# REPL_ID=            # Enables Replit dev plugins — absent on Railway, so plugins are skipped
